<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <title>Haikus for Mona</title>
    <link href="/css/main.css" rel="stylesheet" type="text/css">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta property="og:title" content="Haikus for Mona">
    <meta property="og:description" content="Some of the best haikus you'll ever read about our rescue dog Mona">
    <meta property="og:image" content="/images/sunlight.jpg">
  </head>
  <body>
    <h1>Haikus for Mona</h1>
    <div>
      <% haikus.forEach(haiku => { %>
        <img
          class="mona-images"
          src="/images/<%= haiku.image %>" />
        <div 
          class="haiku-containers">
          <p 
            class="haikus"
          ><%= haiku.text %></p>
        </div>
      <% }); %>
    </div>
  </body>
</html>
